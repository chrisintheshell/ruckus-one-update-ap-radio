# Ruckus One OAuth2 Credentials
# Found in: Administration -> Account Management -> Settings -> Application Token
RUCKUS_TENANT_ID=your-tenant-id
RUCKUS_CLIENT_ID=your-client-id
RUCKUS_CLIENT_SECRET=your-client-secret

# API region base URL (North America: https://api.ruckus.cloud)
RUCKUS_API_BASE_URL=https://api.ruckus.cloud

# Auth URL (North America: https://ruckus.cloud)
RUCKUS_AUTH_BASE_URL=https://ruckus.cloud

# Venue ID
RUCKUS_VENUE_ID=your-venue-id

# AP serial numbers (comma-separated for multiple APs)
RUCKUS_AP_SERIAL_NUMBERS=SERIAL1,SERIAL2
